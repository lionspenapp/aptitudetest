# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (optional – enables material cache writes bypassing RLS)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (optional – enables AI material generation, evaluation, and hints)
# Falls back to mock data when not configured
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (optional alternative LLM provider)
# OPENAI_API_KEY=sk-...

# Stripe (optional – enables premium subscription checkout)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# Dev mode: use shortened timers (10s blocks, 5s distractors)
# NEXT_PUBLIC_INSCRIBE_DEV_TIMERS=true
